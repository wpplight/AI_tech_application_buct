{
  "$schema": "https://wails.io/schemas/config.v3.json",
  "name": "WayFind",
  "outputfilename": "wayfind",
  "frontend": {
    "dir": "../frontend",
    "install": "npm install",
    "build": "npm run build",
    "dev": "npm run dev",
    "devServerUrl": "auto"
  },
  "author": {
    "name": "WayFind Team",
    "email": "team@wayfind.example"
  },
  "info": {
    "companyName": "WayFind",
    "productName": "WayFind Pathfinding Visualizer",
    "productVersion": "1.0.0",
    "copyright": "Copyright 2024",
    "comments": "A pathfinding algorithm visualization tool"
  },
  "wailsjsdir": "../frontend/src/services",
  "version": "3",
  "outputType": "desktop",
  "platforms": ["linux", "darwin", "windows"],
  "rdBounds": {
    "x": 200,
    "y": 200,
    "w": 1280,
    "h": 800
  },
  "nsis": {
    "displayLanguageSelector": false,
    "installerIcon": "./frontend/public/favicon.ico",
    "headerImage": null,
    "license": null,
    "languages": ["English"],
    "licenseFile": null,
    "template": null,
    "threeDimensionalHeaders": false,
    "version": null
  },
  "linux": {
    "icon": "./frontend/public/favicon.ico",
    "category": "Education",
    "shell": null
  },
  "mac": {
    "icon": "./frontend/public/favicon.ico",
    "bundleId": "com.wayfind.app",
    "category": "public.app-category.education",
    "signingIdentity": null,
    "identifier": null,
    "entitlements": null,
    "entitlementsFile": null
  },
  "windows": {
    "icon": "./frontend/public/favicon.ico",
    "webview2installermission": "perUser",
    "allowDowngrade": true,
    "key": null,
    "certificate": null,
    "timestamp": null,
    "wix": null,
    "nsis": {
      "displayLanguageSelector": false,
      "installerIcon": "./frontend/public/favicon.ico",
      "headerImage": null,
      "license": null,
      "languages": ["English"],
      "licenseFile": null,
      "template": null,
      "threeDimensionalHeaders": false,
      "version": null
    }
  }
}
